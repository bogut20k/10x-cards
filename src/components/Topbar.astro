---
import { createClient } from "@/lib/supabase";
const { user } = Astro.locals;

let flashcardCount: number | null = null;
if (user) {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    const { count } = await supabase
      .from("flashcards")
      .select("*", { count: "exact", head: true })
      .eq("user_id", user.id);
    flashcardCount = count;
  }
}
---

<div class="grid grid-cols-3 items-center rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80">
  {
    user ? (
      <>
        <span class="text-blue-100/70">{user.email}</span>
        <div class="flex items-center justify-center gap-4">
          <a href="/dashboard" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Dashboard
          </a>
          <a href="/generate" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Generuj
          </a>
          <a href="/flashcards" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Moje fiszki{flashcardCount ? <sup class="ml-0.5 text-[10px]">({flashcardCount})</sup> : ""}
          </a>
        </div>
        <div class="flex justify-end">
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
              Sign out
            </button>
          </form>
        </div>
      </>
    ) : (
      <>
        <span />
        <span />
        <div class="flex justify-end">
          <a href="/auth/signin" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Sign in
          </a>
        </div>
      </>
    )
  }
</div>
