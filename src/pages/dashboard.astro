---
import Layout from "@/layouts/Layout.astro";
import ManualCardForm from "@/components/flashcards/ManualCardForm";

const saved = Astro.url.searchParams.get("saved");
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 sm:p-8">
    <div class="mx-auto max-w-2xl space-y-4">
      {
        saved && (
          <div class="rounded-xl border border-green-400/30 bg-green-500/15 px-4 py-3 text-center text-sm text-green-200 backdrop-blur-xl">
            Zapisano <strong>{saved}</strong> {Number(saved) === 1 ? "fiszkę" : Number(saved) < 5 ? "fiszki" : "fiszek"}
            !
          </div>
        )
      }

      <ManualCardForm client:load />
    </div>
  </div>
</Layout>
