---
import Layout from "@/layouts/Layout.astro";
import ManualCardForm from "@/components/flashcards/ManualCardForm";

const { user } = Astro.locals;
const saved = Astro.url.searchParams.get("saved");
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 sm:p-8">
    <div class="mx-auto max-w-2xl space-y-4">
      {
        saved && (
          <div class="rounded-xl border border-green-400/30 bg-green-500/15 px-4 py-3 text-center text-sm text-green-200 backdrop-blur-xl">
            Zapisano <strong>{saved}</strong> {Number(saved) === 1 ? "fiszkę" : Number(saved) < 5 ? "fiszki" : "fiszek"}
            !
          </div>
        )
      }

      <div class="rounded-2xl border border-white/10 bg-white/10 px-6 py-4 backdrop-blur-xl">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-blue-100/60">Zalogowany jako</p>
            <p class="font-semibold text-white">{user?.email}</p>
          </div>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
            >
              Wyloguj
            </button>
          </form>
        </div>
      </div>

      <ManualCardForm client:only="react" />
    </div>
  </div>
</Layout>
