---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";

const code = Astro.url.searchParams.get("code");
const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");

let exchangeError: string | null = null;
let sessionReady = false;

if (code) {
  const supabase = createClient(Astro.request.headers, Astro.cookies);
  if (supabase) {
    const { error: err } = await supabase.auth.exchangeCodeForSession(code);
    if (err) {
      exchangeError = err.message;
    } else {
      sessionReady = true;
    }
  }
}
---

<Layout title="Set new password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent">
        Set new password
      </h1>

      {(exchangeError || (!code && !success)) && (
        <div class="rounded-lg border border-red-400/30 bg-red-500/20 px-4 py-3 text-center text-sm text-red-200">
          {exchangeError ?? "Invalid or expired reset link."}
          <div class="mt-3">
            <a href="/auth/forgot-password" class="text-purple-300 hover:underline">Request a new link</a>
          </div>
        </div>
      )}

      {error && (
        <div class="mb-4 rounded-lg border border-red-400/30 bg-red-500/20 px-4 py-3 text-sm text-red-200">
          {error}
        </div>
      )}

      {success && (
        <div class="rounded-lg border border-green-400/30 bg-green-500/15 px-4 py-3 text-center text-sm text-green-200">
          Password updated! <a href="/auth/signin" class="text-purple-300 hover:underline">Sign in</a>
        </div>
      )}

      {sessionReady && (
        <form method="POST" action="/api/auth/reset-password" class="space-y-4">
          <div>
            <label for="password" class="mb-1.5 block text-sm font-medium text-blue-100/80">New password</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              minlength="8"
              placeholder="Min. 8 characters"
              class="w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder-blue-100/40 focus:border-blue-400/50 focus:outline-none focus:ring-1 focus:ring-blue-400/50"
            />
          </div>
          <div>
            <label for="confirm" class="mb-1.5 block text-sm font-medium text-blue-100/80">Confirm password</label>
            <input
              id="confirm"
              name="confirm"
              type="password"
              required
              placeholder="Repeat password"
              class="w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder-blue-100/40 focus:border-blue-400/50 focus:outline-none focus:ring-1 focus:ring-blue-400/50"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-purple-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-purple-500"
          >
            Update password
          </button>
        </form>
      )}
    </div>
  </div>
</Layout>
