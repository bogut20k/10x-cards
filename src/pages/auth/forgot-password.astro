---
import Layout from "@/layouts/Layout.astro";

const error = Astro.url.searchParams.get("error");
const sent = Astro.url.searchParams.get("sent");
---

<Layout title="Reset password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent">
        Reset password
      </h1>
      <p class="mb-6 text-center text-sm text-blue-100/60">
        Enter your email and we'll send you a reset link.
      </p>

      {error && (
        <div class="mb-4 rounded-lg border border-red-400/30 bg-red-500/20 px-4 py-3 text-sm text-red-200">
          {error}
        </div>
      )}

      {sent ? (
        <div class="rounded-lg border border-green-400/30 bg-green-500/15 px-4 py-3 text-center text-sm text-green-200">
          Check your email for the reset link.
        </div>
      ) : (
        <form method="POST" action="/api/auth/forgot-password" class="space-y-4">
          <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-blue-100/80">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="you@example.com"
              class="w-full rounded-lg border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder-blue-100/40 focus:border-blue-400/50 focus:outline-none focus:ring-1 focus:ring-blue-400/50"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-purple-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-purple-500"
          >
            Send reset link
          </button>
        </form>
      )}

      <p class="mt-4 text-center text-sm text-blue-100/60">
        <a href="/auth/signin" class="text-purple-300 hover:underline">Back to sign in</a>
      </p>
    </div>
  </div>
</Layout>
